---
import SiteLayout from '../../layouts/SiteLayout.astro';

const pillars = [
  {
    title: 'Mold configuration',
    text: 'Mastering the process: determine accurately and fast which elements of a mold are required based on the geometry of the 3D CAD file.',
  },
  {
    title: 'Purchased parts',
    text: 'Identifying automatically – based on pre-set templates – which materials and purchased parts from a comprehensive library are the best fit for the project.',
  },
  {
    title: 'Manufacturing effort',
    text: 'Calculating the manufacturing effort based on adaptable configurations per mold element, combined with a database of machines and production sites.',
  },
];

const features = [
  'Three tool technologies: mold / cast / stamp',
  '3D layouting of the mold nest and cavities including CAD export',
  'Algorithm to define the parting opening direction',
  'Undercut identification and slider concept definition',
  'Smart feature recognition of additional cost drivers (inserts, eroded areas)',
  'Database of manufacturing locations, hour rates, materials and purchased parts',
  'Selection of predefined and customer-specific tool templates',
  'Central library – customizable and extendible',
  'Comprehensive cost breakdown – clustered by mold elements and manufacturing processes',
  'Export of calculations via JSON/XML or customer-specific reports',
  'Save calculations into your database to run big-data analysis',
];

const nav = [
  { id: 'overview', label: 'Overview' },
  { id: 'pillars', label: 'Three pillars' },
  { id: 'features', label: 'Features' },
  { id: 'who', label: 'Who is it for' },
  { id: 'try', label: 'Try it' },
];
---
<SiteLayout
  title="mido – Tool Cost Calculation | Teraport"
  lang="en"
  description="mido: tool cost calculation from 3D CAD models – rule-based, visually supported, with automatic cost driver recognition."
  altHref="/de/mido/"
>
  <section class="intro">
    <div class="tp-container">
      <p class="kicker">mido · Tool Cost Calculation</p>
      <h1>the right price at your fingertips</h1>
      <p class="sub">Tool cost calculation from 3D CAD models – fast, transparent, traceable.</p>
      <div class="actions">
        <a class="btn primary" href="https://www.vxmido.com" rel="noopener">Get a free test license</a>
        <a class="btn secondary" href="/en/contact/">Get in touch</a>
      </div>
    </div>
  </section>

  <nav class="subnav" aria-label="Sections">
    <div class="tp-container row">
      {nav.map((n) => <a href={`#${n.id}`}>{n.label}</a>)}
    </div>
  </nav>

  <section id="overview" class="block reveal">
    <div class="tp-container narrow">
      <h2>Overview</h2>
      <p>Managing costs is a key ability in modern product development projects. Looking at key technologies such as plastic injection molding, die casting or sheet-metal stamping, mold and tool costs are the single most determining cost factor for the part's end price.</p>
      <p>With <strong>mido</strong>, tool cost calculation is transformed into an easy-to-do task: visually supported, rule-based mold and tool configuration combined with automatic cost driver recognition on 3D CAD models enables even non-experienced users to complete meaningful calculations in little time.</p>
    </div>
  </section>

  <section id="pillars" class="block band reveal">
    <div class="tp-container">
      <h2>The three pillars</h2>
      <p class="lead">mido supports you in determining three key features of your mold project:</p>
      <div class="cards">
        {pillars.map((p, i) => (
          <article class="card">
            <span class="num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{p.title}</h3>
            <p>{p.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="features" class="block reveal">
    <div class="tp-container narrow">
      <h2>Features in detail</h2>
      <ul class="checklist">
        {features.map((f) => <li>{f}</li>)}
      </ul>
    </div>
  </section>

  <section id="who" class="block band reveal">
    <div class="tp-container narrow">
      <h2>Who is it for?</h2>
      <p>Tool and mold makers, OEMs and suppliers in injection molding, die casting and stamping – wherever tool costs need to be assessed early, quickly and reliably.</p>
    </div>
  </section>

  <section id="try" class="block cta reveal">
    <div class="tp-container narrow center">
      <h2>Experience it!</h2>
      <p class="lead">See for yourself – with a free test license.</p>
      <div class="actions center">
        <a class="btn primary" href="https://www.vxmido.com" rel="noopener">Request a test license → vxmido.com</a>
        <a class="btn ghost" href="/en/contact/">or contact us directly</a>
      </div>
    </div>
  </section>
</SiteLayout>

<script>
  const els = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver(
    (entries) => entries.forEach((e) => e.isIntersecting && e.target.classList.add('visible')),
    { threshold: 0.12 }
  );
  els.forEach((el) => io.observe(el));
</script>

<style is:global>
  html { scroll-behavior: smooth; }
</style>
<style>
  .intro { background: var(--tp-gray-900); color: var(--tp-gray-100); padding-block: 4rem 3rem; }
  .kicker { color: var(--tp-gray-500); font-family: var(--tp-font-accent); font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.8125rem; margin: 0 0 0.75rem; }
  .intro h1 { color: var(--tp-gray-100); font-size: clamp(1.9rem, 4vw, 3rem); line-height: 1.1; margin: 0 0 0.75rem; }
  .sub { color: var(--tp-gray-400); max-width: 50ch; margin: 0 0 1.5rem; }
  .actions { display: flex; gap: 0.9rem; flex-wrap: wrap; }
  .actions.center { justify-content: center; }
  .btn { display: inline-flex; align-items: center; padding: 0.7rem 1.4rem; border-radius: 9px; border: 1px solid transparent; font-family: var(--tp-font-accent); font-weight: 600; font-size: 0.9375rem; text-decoration: none; }
  .btn.primary { background: var(--tp-orange-400); color: var(--tp-gray-900); }
  .btn.primary:hover { filter: brightness(1.06); color: var(--tp-gray-900); }
  .btn.secondary { border-color: rgb(255 255 255 / 28%); color: var(--tp-gray-100); }
  .btn.secondary:hover { border-color: rgb(255 255 255 / 55%); color: var(--tp-gray-100); }
  .btn.ghost { color: var(--tp-orange-500); }

  .subnav { position: sticky; top: 0; z-index: 30; background: var(--tp-gray-100); border-bottom: 1px solid var(--tp-gray-300); }
  .subnav .row { display: flex; gap: 1.5rem; flex-wrap: wrap; padding-block: 0.6rem; }
  .subnav a { color: var(--tp-gray-600); text-decoration: none; font-family: var(--tp-font-accent); font-weight: 600; font-size: 0.875rem; }
  .subnav a:hover { color: var(--tp-orange-500); }

  .block { padding-block: 3.5rem; scroll-margin-top: 4.5rem; }
  .band { background: var(--tp-gray-200); }
  .narrow { max-width: 46rem; }
  .center { text-align: center; }
  .lead { color: var(--tp-gray-600); font-size: 1.1rem; }
  .block p { color: var(--tp-gray-600); }
  .block h2 { margin-top: 0; }

  .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.25rem; margin-top: 1.5rem; }
  .card { background: var(--tp-gray-0); border: 1px solid rgb(0 0 0 / 5%); border-radius: 14px; padding: 1.5rem; box-shadow: 0 1px 3px rgb(0 0 0 / 8%); }
  .num { color: var(--tp-orange-400); font-family: var(--tp-font-accent); font-weight: 700; font-size: 0.9rem; }
  .card h3 { margin: 0.35rem 0 0.5rem; font-family: var(--tp-font-accent); font-weight: 700; font-size: 1.15rem; }
  .card p { margin: 0; }

  .checklist { list-style: none; padding: 0; margin: 1.25rem 0 0; display: grid; gap: 0.5rem; }
  .checklist li { padding-left: 1.6rem; position: relative; color: var(--tp-gray-600); }
  .checklist li::before { content: '✓'; position: absolute; left: 0; color: var(--tp-orange-400); font-weight: 700; }

  .cta { background: var(--tp-gray-900); }
  .cta h2, .cta .lead { color: var(--tp-gray-100); }
  .cta .lead { color: var(--tp-gray-400); }

  .reveal { opacity: 0; transform: translateY(16px); transition: opacity 0.5s ease, transform 0.5s ease; }
  .reveal.visible { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }
</style>
