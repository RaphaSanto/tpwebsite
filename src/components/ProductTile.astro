---
interface Props { title: string; teaser: string; href: string; more: string; }
const { title, teaser, href, more } = Astro.props;
---
<a class="tile" href={href}>
  <h3>{title}</h3>
  <p>{teaser}</p>
  <span class="more">{more} →</span>
</a>
<style>
  /* Brandbook v2: weiße Karte, Radius 14, Name Space Grotesk 700, Link orange-500 */
  .tile { display: flex; flex-direction: column; gap: 0.5rem; background: var(--tp-gray-0); border: 1px solid rgb(0 0 0 / 5%); border-radius: 14px; padding: 1.5rem; text-decoration: none; color: var(--tp-ink); box-shadow: 0 1px 3px rgb(0 0 0 / 8%); transition: box-shadow 0.15s ease, border-color 0.15s ease; }
  .tile:hover { border-color: var(--tp-orange-400); box-shadow: 0 6px 20px rgb(0 0 0 / 12%); }
  h3 { margin: 0; font-size: 1.35rem; color: var(--tp-gray-900); font-family: var(--tp-font-accent); font-weight: 700; }
  p { margin: 0; color: var(--tp-gray-600); }
  .more { color: var(--tp-orange-500); font-family: var(--tp-font-accent); font-weight: 600; font-size: 0.9rem; margin-top: auto; }
</style>
