---
interface Props { title: string; teaser: string; href: string; more: string; }
const { title, teaser, href, more } = Astro.props;
---
<a class="tile" href={href}>
  <h3>{title}</h3>
  <p>{teaser}</p>
  <span class="more">{more} →</span>
</a>
<style>
  /* Schema D: weiße Karte auf grauem Band, Produktname dunkel, Orange nur beim Link */
  .tile { display: flex; flex-direction: column; gap: 0.5rem; background: var(--tp-white); border: 1px solid #ececee; border-radius: 12px; padding: 1.5rem; text-decoration: none; color: var(--tp-ink); box-shadow: 0 2px 10px rgb(24 24 27 / 5%); transition: box-shadow 0.15s ease, border-color 0.15s ease; }
  .tile:hover { border-color: var(--tp-blue); box-shadow: 0 6px 20px rgb(24 24 27 / 10%); }
  h3 { margin: 0; font-size: 1.35rem; color: var(--tp-ink); }
  p { margin: 0; color: var(--tp-body); }
  .more { color: var(--tp-blue); font-weight: 700; font-size: 0.9rem; margin-top: auto; }
</style>
