---
import type { Lang } from '../i18n/ui.ts';
interface Props { title: string; date: Date; href: string; lang: Lang; image?: string; }
const { title, date, href, lang, image } = Astro.props;
const fmt = date.toLocaleDateString(lang === 'de' ? 'de-DE' : 'en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
---
<a class="card" href={href}>
  {image && <img class="thumb" src={image} alt="" loading="lazy" />}
  <div class="body">
    <time datetime={date.toISOString().slice(0, 10)}>{fmt}</time>
    <h3>{title}</h3>
  </div>
</a>
<style>
  /* Schema D: weiße Karte, Datum in Versalien */
  .card { display: block; background: var(--tp-white); border: 1px solid #ececee; border-radius: 12px; overflow: hidden; text-decoration: none; color: var(--tp-ink); box-shadow: 0 2px 10px rgb(24 24 27 / 5%); transition: border-color 0.15s ease, box-shadow 0.15s ease; }
  .card:hover { border-color: var(--tp-blue); box-shadow: 0 6px 20px rgb(24 24 27 / 10%); }
  .thumb { width: 100%; aspect-ratio: 16 / 7; object-fit: cover; }
  .body { padding: 1.1rem 1.25rem; }
  time { color: var(--tp-gray); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600; }
  h3 { margin: 0.3rem 0 0; font-size: 1.05rem; line-height: 1.35; }
</style>
