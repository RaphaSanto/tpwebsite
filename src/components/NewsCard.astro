---
import type { Lang } from '../i18n/ui.ts';
interface Props { title: string; date: Date; href: string; lang: Lang; image?: string; }
const { title, date, href, lang, image } = Astro.props;
const fmt = date.toLocaleDateString(lang === 'de' ? 'de-DE' : 'en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
---
<a class="card" href={href}>
  {image && <img class="thumb" src={image} alt="" loading="lazy" />}
  <div class="body">
    <time datetime={date.toISOString().slice(0, 10)}>{fmt}</time>
    <h3>{title}</h3>
  </div>
</a>
<style>
  /* Brandbook v2: weiße Karte Radius 14, Bildfenster 176px, Titel Space Grotesk 600 */
  .card { display: block; background: var(--tp-gray-0); border: 1px solid rgb(0 0 0 / 5%); border-radius: 14px; overflow: hidden; text-decoration: none; color: var(--tp-ink); box-shadow: 0 1px 3px rgb(0 0 0 / 8%); transition: border-color 0.15s ease, box-shadow 0.15s ease; }
  .card:hover { border-color: var(--tp-orange-400); box-shadow: 0 6px 20px rgb(0 0 0 / 12%); }
  .thumb { width: 100%; height: 176px; object-fit: cover; }
  .body { padding: 1.1rem 1.25rem; }
  time { color: var(--tp-gray-500); font-family: var(--tp-font-accent); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; }
  h3 { margin: 0.3rem 0 0; font-size: 1.05rem; line-height: 1.35; font-family: var(--tp-font-accent); font-weight: 600; color: var(--tp-gray-900); }
</style>
