---
interface Props {
  kicker: string; title: string; ctaLabel: string; ctaHref: string;
  subline?: string; cta2Label?: string; cta2Href?: string; imageLabel?: string;
}
const {
  kicker, title, ctaLabel, ctaHref,
  subline = '', cta2Label = '', cta2Href = '#', imageLabel = '',
} = Astro.props;
---
<section class="hero">
  <div class="tp-container grid">
    <div>
      <p class="kicker">{kicker}</p>
      <h1>{title}</h1>
      {subline && <p class="subline">{subline}</p>}
      <div class="actions">
        <a class="cta" href={ctaHref}>{ctaLabel}</a>
        {cta2Label && <a class="cta2" href={cta2Href}>{cta2Label}</a>}
      </div>
    </div>
    {imageLabel && (
      <div class="media" aria-hidden="true"><span>{imageLabel}</span></div>
    )}
  </div>
</section>
<style>
  /* Schema D: dunkler Hero mit Subline, zwei CTAs und Bild-Slot */
  .hero { background: linear-gradient(135deg, #18181b 0%, #303036 100%); color: var(--tp-white); padding-block: 4.5rem; }
  .grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 3rem; align-items: center; }
  @media (max-width: 820px) { .grid { grid-template-columns: 1fr; } }
  .kicker { color: #d4d4d8; letter-spacing: 0.08em; text-transform: uppercase; font-size: 0.85rem; font-weight: 700; margin: 0 0 0.75rem; }
  h1 { color: var(--tp-white); font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; margin: 0 0 1rem; max-width: 24ch; }
  .subline { color: #d4d4d8; max-width: 46ch; margin: 0 0 1.5rem; }
  .actions { display: flex; gap: 0.9rem; flex-wrap: wrap; }
  .cta { display: inline-block; background: var(--tp-blue); color: #18181b; font-weight: 700; padding: 0.7rem 1.4rem; border-radius: 8px; text-decoration: none; }
  .cta:hover { filter: brightness(1.08); }
  .cta2 { display: inline-block; border: 1px solid #6a6a6b; color: var(--tp-white); font-weight: 600; padding: 0.7rem 1.4rem; border-radius: 8px; text-decoration: none; }
  .cta2:hover { border-color: #d4d4d8; }
  .media { border: 1px dashed #52525b; border-radius: 12px; min-height: 280px; display: grid; place-items: center; color: #9c9d9f; font-size: 0.9rem; }
</style>
