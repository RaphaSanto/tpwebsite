---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
interface Props {
  kicker: string; title: string; ctaLabel: string; ctaHref: string;
  subline?: string; cta2Label?: string; cta2Href?: string;
  image?: ImageMetadata; imageAlt?: string;
}
const {
  kicker, title, ctaLabel, ctaHref,
  subline = '', cta2Label = '', cta2Href = '#',
  image, imageAlt = '',
} = Astro.props;
---
<section class="hero">
  <div class="tp-container grid">
    <div>
      <p class="kicker">{kicker}</p>
      <h1>{title}</h1>
      {subline && <p class="subline">{subline}</p>}
      <div class="actions">
        <a class="btn primary" href={ctaHref}>{ctaLabel}</a>
        {cta2Label && <a class="btn secondary" href={cta2Href}>{cta2Label}</a>}
      </div>
    </div>
    {image && (
      <div class="media">
        <div class="frame">
          <Image src={image} alt={imageAlt} width={500} height={400} />
        </div>
      </div>
    )}
  </div>
</section>
<style>
  /* Brandbook v2: flächiger Hero gray-900, Righteous-Headline, Space-Grotesk-Kicker/Buttons */
  .hero { background: var(--tp-gray-900); color: var(--tp-gray-100); padding-block: 4.5rem; }
  .grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 3rem; align-items: center; }
  @media (max-width: 820px) { .grid { grid-template-columns: 1fr; } }
  .kicker {
    color: var(--tp-gray-500); font-family: var(--tp-font-accent); font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.8125rem; margin: 0 0 0.75rem;
  }
  h1 { color: var(--tp-gray-100); font-size: clamp(2rem, 4.5vw, 3.25rem); line-height: 1.08; margin: 0 0 1rem; max-width: 24ch; }
  .subline { color: var(--tp-gray-400); max-width: 46ch; margin: 0 0 1.5rem; }
  .actions { display: flex; gap: 0.9rem; flex-wrap: wrap; align-items: stretch; }
  .btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 0.7rem 1.4rem; border-radius: 9px; border: 1px solid transparent;
    font-family: var(--tp-font-accent); font-weight: 600; font-size: 0.9375rem; line-height: 1.2; text-decoration: none;
  }
  .btn.primary { background: var(--tp-orange-400); color: var(--tp-gray-900); }
  .btn.primary:hover { filter: brightness(1.06); }
  .btn.secondary { background: transparent; border-color: rgb(255 255 255 / 28%); color: var(--tp-gray-100); }
  .btn.secondary:hover { border-color: rgb(255 255 255 / 55%); }
  .media { display: grid; place-items: center; }
  /* Passepartout: der Rahmen beschneidet jede Grafik (auch quadratische) auf 5:4 mit runden Ecken */
  .frame {
    width: min(100%, 500px); aspect-ratio: 5 / 4;
    border-radius: 12px; overflow: hidden;
    background: var(--tp-gray-200);
  }
  .frame img { width: 100%; height: 100%; object-fit: cover; display: block; }
</style>
